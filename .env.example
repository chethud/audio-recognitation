# Copy to `.env` in the project root. Do not commit `.env`.
# Keys: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://ljxarxkxlgzkueedlrbi.supabase.co

# Prefer service_role for this FastAPI backend (Storage upload + table insert).
SUPABASE_SERVICE_ROLE_KEY=

